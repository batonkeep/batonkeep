# Environment configuration — copy to .env and fill in as needed

# ── Compose project name ──────────────────────────────────────────────────────
# Pins the Compose project name so container + volume names are deterministic
# (e.g. batonkeep_appdata, batonkeep_agent_home) regardless of the folder you
# installed into. Without this, Compose derives the name from the directory, so
# the backup/volume commands in docs/self-hosting.md would not match. Honored by
# both `docker compose` (v2) and the legacy `docker-compose` (v1). Keep it set.
COMPOSE_PROJECT_NAME=batonkeep

# ── Web exposure ──────────────────────────────────────────────────────────────
# Only the frontend is published to the host; it reverse-proxies /api + /ws to the
# backend internally. The app is single-origin, so share/publish URLs derive from
# whatever public domain you front it with — no base-URL config needed.
#   WEB_PORT   host port for the web UI (default 8080)
#   WEB_BIND   host interface; set 127.0.0.1 to expose only to a local cloudflared
#              tunnel, leave 0.0.0.0 for direct LAN/VPS access. See docs/self-hosting.md.
# WEB_PORT=8080
# WEB_BIND=0.0.0.0

# ── Deployment ──────────────────────────────────────────────────────────────
# personal | oss | managed
# managed hard-disables plan-CLI mode at startup (legal guardrail, §1a)
DEPLOYMENT_MODE=personal

# ── Identity ─────────────────────────────────────────────────────────────────
OWNER_ID=local

# ── Credential mode ───────────────────────────────────────────────────────────
# plan | byo_key | hosted
DEFAULT_CRED_MODE=plan

# ── Routing defaults ──────────────────────────────────────────────────────────
# Comma-separated ordered candidate list (provider instance ids).
# Ships as "mock" so a fresh clone runs with zero credentials.
# Switch to "claude,grok,agy,codex" (or subset) after `make auth`.
# Bare names are each provider's default account; "claude:work" is an extra
# instance declared in PROVIDER_INSTANCES_CONFIG (see below).
DEFAULT_CANDIDATES=mock

# ── Provider instances (multiple subscriptions per provider) ──────────────────
# Optional. Path INSIDE the container to a JSON file declaring extra accounts of
# a provider (e.g. two Claude subscriptions) for rate-limit spreading. Each gets
# its own auth + independent cooldown. The file must live on a mounted volume
# (use /data, the appdata volume). Loaded once at startup — restart the backend
# after changing it. Template: backend/config/provider-instances.example.json.
# CLI account login: declare cli_config_dir under /home/agent, then:
#   make auth p=claude:work
# PROVIDER_INSTANCES_CONFIG=/data/provider-instances.json

# ── Concurrency ───────────────────────────────────────────────────────────────
PER_PROVIDER_CONCURRENCY=1
MAX_CONCURRENT_RUNS=4
RUN_TIMEOUT_SECONDS=1800

# ── Behaviour ─────────────────────────────────────────────────────────────────
AUTONOMOUS_TOOLS=true
SEED_EXAMPLES=true

# ── Security ──────────────────────────────────────────────────────────────────
# Required: random secret used to encrypt BYO-key credentials at rest.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET=

# ── App login gate (personal/oss) ─────────────────────────────────────────────
# Set a password to require login for the whole app — this protects your *data*
# and UI, not just the console. Strongly recommended for any non-localhost or
# shared deployment. Empty ⇒ no gate (backward-compatible dev default).
# Multi-user accounts are a managed-mode concern.
# APP_PASSWORD=
# Mark the session cookie Secure (HTTPS-only). Leave unset for plain-http LAN
# self-hosting. Set true when the app is reached over TLS — e.g. behind a
# cloudflared tunnel or a TLS-terminating reverse proxy.
# COOKIE_SECURE=false

# ── In-UI console (scoped actions: set models, run auth) ──────────────────────
# Lets the Providers panel set a model per plan and run the CLI auth flow from the
# UI. It execs the project's auth.sh inside the container (never an arbitrary
# command), so it is OFF by default and never available in DEPLOYMENT_MODE=managed.
# When APP_PASSWORD is set, the console rides your login session — no separate
# token needed. Without app-auth, set WEB_CONSOLE_TOKEN as the legacy access gate.
# ENABLE_WEB_CONSOLE=false
# WEB_CONSOLE_TOKEN=    # legacy gate; only needed when APP_PASSWORD is unset. generate: python -c "import secrets; print(secrets.token_hex(16))"

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path inside the container (mounted on appdata volume)
DATABASE_URL=sqlite+aiosqlite:////data/batonkeep.db

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUTS_DIR=/data/outputs

# ── Optional: API key providers (overflow / BYO-key) ─────────────────────────
# Uncomment and fill in to enable metered API providers.
# These are never required for the mock or plan-CLI paths.

# OpenAI-compatible open-model host (e.g. Together, Fireworks, self-hosted vLLM)
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_API_KEY=

# Anthropic API (BYO-key fallback)
# ANTHROPIC_API_KEY=

# xAI Grok API key → enables the `grok-api` provider (OpenAI-compatible, api.x.ai)
# XAI_API_KEY=

# Google Gemini API key → enables the `gemini-api` provider (OpenAI-compatible endpoint)
# GEMINI_API_KEY=

# ── Web search (SearXNG) ──────────────────────────────────────────────────────
# The `web_search` tool uses the bundled self-hosted SearXNG service by default
# (no key, multi-engine). Leave these as-is for the default internal instance.
#   • Point at an external SearXNG instead:  SEARXNG_URL=https://searx.example.org
#   • Disable SearXNG (use the DuckDuckGo scrape only):  SEARXNG_URL=
# DuckDuckGo is always the automatic fallback when SearXNG is unset or unreachable.
# SEARXNG_URL=http://searxng:8080
# Secret for the internal SearXNG instance (only matters if you expose it).
# SEARXNG_SECRET=batonkeep-internal-searxng

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
